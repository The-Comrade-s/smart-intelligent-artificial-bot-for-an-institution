# --- App ---
APP_NAME=COSIB
APP_ENV=development
DEBUG=true
# In production these should be your actual Railway backend URL and Vercel
# frontend URL respectively.
BACKEND_BASE_URL=http://localhost:8000
FRONTEND_BASE_URL=http://localhost:5173

# --- Security ---
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=CHANGE_ME_TO_A_LONG_RANDOM_STRING
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=14

# --- Database: Supabase PostgreSQL ---
# Use the "Direct connection" string from Supabase (Project Settings ->
# Database -> Connection string), NOT the Transaction Pooler (port 6543) —
# this app's SQLAlchemy async engine uses its own connection pool and
# asyncpg's prepared statements, which don't play well with pgbouncer's
# transaction-pooling mode without extra configuration this app doesn't
# currently add. The Session Pooler (also port 5432, different host) is a
# safe alternative if you're on a Supabase plan with a low direct-connection
# limit. Rewrite postgres:// as postgresql+asyncpg:// (async) /
# postgresql+psycopg2:// (sync, used by some tooling) as shown below.
DATABASE_URL=postgresql+asyncpg://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres
DATABASE_URL_SYNC=postgresql+psycopg2://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres

# --- CORS ---
# Your Vercel production domain (and any custom domain), comma-separated.
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,https://cosib-frontend.vercel.app
# Optional: allow Vercel preview-deployment URLs (unique per branch/PR).
# Leave blank to disable. Example: https://cosib-frontend.*\.vercel\.app
CORS_ORIGIN_REGEX=

# --- AI Providers (leave blank to use the mock provider added in ES-002) ---
AI_PROVIDER_DEFAULT=mock
GEMINI_API_KEY=
OPENAI_API_KEY=

# --- Uploads ---
# Uploaded documents are processed in-memory for text extraction and are
# not currently persisted to disk (see app/api/v1/documents.py) — so this
# is unaffected by Railway's ephemeral filesystem. UPLOAD_DIR/uploads/ is
# reserved for a future persistent-storage feature (Supabase Storage would
# be the natural fit if that's added later).
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=15
ALLOWED_UPLOAD_EXTENSIONS=pdf,docx,txt

# --- Seed data (used by scripts/seed.py) ---
SEED_ADMIN_EMAIL=admin@cosib.local
SEED_ADMIN_PASSWORD=ChangeMe123!

# --- Branding ---
INSTITUTION_NAME=Gateway ICT Polytechnic, Saapade
DEPARTMENT_NAME=Computer Science Department
